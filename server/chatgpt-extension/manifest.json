{
    "manifest_version": 3,
    "name": "VCW ChatGPT Bridge",
    "version": "1.1",
    "description": "Connects Video Creator Workflow to ChatGPT",
    "permissions": [
        "tabs",
        "scripting"
    ],
    "host_permissions": [
        "https://chatgpt.com/*",
        "http://localhost:3001/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html"
    },
    "icons": {}
}