# ═══════════════════════════════════════
# LOCAL DEVELOPMENT ENVIRONMENT
# Copy this to .env when running locally
# ═══════════════════════════════════════

DATABASE_URL="file:./dev.db"
JWT_SECRET="vcw-super-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"
PORT=3001
REDIS_URL="redis://localhost:6379"
UPLOAD_DIR="./uploads"

# Chrome (macOS local)
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Telegram Bot — POLLING mode for local dev
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_URL=

# AI Provider
TELEGRAM_AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
OPENROUTER_API_KEY=

# Local Ollama (self-hosted LLM on this server; OpenAI-compatible at /v1, native at /api/chat)
# Server reaches it locally with NO auth; the nginx basic-auth only gates external /ollama/ access.
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Root-owned wrapper used by the admin "change LLM password" feature (VPS only):
# OLLAMA_PW_WRAPPER=/usr/local/sbin/vcw-ollama-pw

# Google Flow Python broker (invisible_playwright Firefox)
# Start locally with: cd python-broker && ./venv/bin/python -m broker
FLOW_BROKER_URL=http://127.0.0.1:8002
# BROKER_AUTH_TOKEN=  # optional bearer secret if broker.env sets one

# Cookie Harvester Cron (set to true to disable automatic background cookie refresh/login)
# DISABLE_COOKIE_HARVESTER=true
