# Mac MCP broker — local Docker Desktop deployment.
# Plan v4.3 — see MIGRATION-MAC-MCP.md.
#
# Copy to `.env` (in this directory) and fill in the token:
#   cp .env.example .env
#   # Generate a random 32-byte hex token:
#   echo "BROKER_AUTH_TOKEN=$(openssl rand -hex 32)" > .env
#
# The token is read by docker-compose.yml `${BROKER_AUTH_TOKEN:?...}` and passed to
# the broker container as BROKER_AUTH_TOKEN. The MCP server's `mcp-server/.env` must
# set MCP_BROKER_TOKEN to the SAME value.

# Shared secret — defense-in-depth on top of localhost-only bind.
# Use `openssl rand -hex 32` to generate. Min 32 chars.
BROKER_AUTH_TOKEN=
