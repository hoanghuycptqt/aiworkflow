# Copy to /opt/vcw/app/python-broker/broker.env on the VPS.
# Defaults are safe; only set BROKER_AUTH_TOKEN if you want bearer auth on the loopback API.
# NOTE: BROKER_AUTH_TOKEN must MATCH the server's BROKER_AUTH_TOKEN (server reads
# it from server/.env via process.env) or every broker call returns 401.

# BROKER_HOST=127.0.0.1
# BROKER_PORT=8002
# BROKER_AUTH_TOKEN=<generate via: openssl rand -hex 32>
# BROKER_ROTATION_THRESHOLD=15
# Idle close (seconds). Set 0 to keep Firefox warm FOREVER (no idle-close) — the
# thhflow VPS uses 0 (23G RAM box) to avoid cold-launch reCAPTCHA trust-score 403s.
# Context still rotates @ BROKER_ROTATION_THRESHOLD regardless, so trust stays fresh.
BROKER_IDLE_TIMEOUT_S=0

# Browser engine: invisible (x86_64 invisible_playwright — the PROVEN engine; runs
# under FEX-Emu on the aarch64 VPS, natively on Mac) | camoufox (tried on the VPS and
# FAILS reCAPTCHA on Flow — grecaptcha never inits — do NOT use). The systemd unit
# already pins BROKER_BROWSER_ENGINE=invisible + HOME on the VPS; only override here
# if you relocate the venv/cache.
# BROKER_BROWSER_ENGINE=invisible
BROKER_PROFILE_BASE=/opt/vcw/broker-profiles
